<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/micName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/mic_unknown"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/elapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/elapsed_zero"
        android:textSize="44sp"
        android:fontFamily="monospace"
        android:layout_marginTop="12dp"
        android:layout_gravity="center_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/maxDbfs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/max_init"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/minDbfs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/min_init"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:textColor="#888888"
            android:gravity="end" />
    </LinearLayout>

    <com.iamweasel89.birdscope.SpectrumView
        android:id="@+id/spectrum"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:minHeight="160dp" />

    <Button
        android:id="@+id/recordButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/start"
        android:textSize="20sp"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/fileInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/file_size_none"
        android:textSize="14sp"
        android:layout_marginTop="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33000000"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/checkUpdateButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/check_update"
        android:textSize="14sp"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/updateStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/buildInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="6dp" />

</LinearLayout>