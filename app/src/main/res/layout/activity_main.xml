<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:title="@string/app_name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tagF1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="F1"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_gravity="start"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/micName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mic_unknown"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/elapsed_zero"
            android:textSize="48sp"
            android:fontFamily="monospace"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tagF7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="F7"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_gravity="start"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/maxDbfs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/max_init"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/minDbfs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/min_init"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:textColor="#888888"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/tagF8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="F8"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_gravity="start"
            android:layout_marginTop="12dp" />

        <com.iamweasel89.birdscope.SpectrumView
            android:id="@+id/spectrum"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:minHeight="160dp" />

        <Button
            android:id="@+id/recordButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/start"
            android:textSize="22sp"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/fileInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/file_size_none"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/updateStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/buildInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</LinearLayout>
